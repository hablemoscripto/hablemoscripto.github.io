# ─────────────────────────────────────────────────────────────
# Local development (.env.local) — values used by `npm run dev`
# and the seed script. Production values live in Vercel and
# Supabase dashboards; see PRODUCTION-CHECKLIST.md.
# ─────────────────────────────────────────────────────────────

# Supabase (required — already configured)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Service Key (for `npm run db:seed` only — NOT prefixed with VITE_
# to avoid exposure in the client bundle)
SUPABASE_SERVICE_KEY=your_supabase_service_key

# Wompi Payment Gateway (client-side)
# Use pub_test_* during development; pub_prod_* in production Vercel env.
VITE_WOMPI_PUBLIC_KEY=pub_test_your_public_key

# Wompi secrets — server-side only, set as Supabase Edge Function secrets
# in production. Only declared here so local tooling (edge function
# emulator) can pick them up.
WOMPI_PRIVATE_KEY=prv_test_your_private_key
WOMPI_EVENTS_SECRET=your_events_secret
WOMPI_INTEGRITY_SECRET=your_integrity_secret

# Resend (server-side only — Supabase Edge Function secret in production)
RESEND_API_KEY=re_your_api_key_here

# Google Analytics 4 — optional. No-ops if unset. Only fires in prod build.
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Error reporting endpoint — optional. No-ops if unset.
VITE_ERROR_REPORTING_URL=

# Solana USDC payment address — optional. Falls back to a hardcoded
# placeholder. Must be set in both frontend (VITE_*) and Edge Function
# (unprefixed) envs for crypto payments to work end-to-end.
VITE_USDC_PAYMENT_ADDRESS=
USDC_PAYMENT_ADDRESS=
SOLANA_RPC_URL=
